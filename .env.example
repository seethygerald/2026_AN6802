# Copy this file to .env in the project root for one-command local startup
# cp .env.example .env

# Required for equity/RAG
GEMINI_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=demo_collection

# Choose ONE provider for embeddings
# - external: hosted embedding endpoint (recommended for low-memory deploys)
# - local: offline/local testing (requires requirements_for_ingestion.txt)
EMBEDDING_PROVIDER=external

# external provider mode
EMBEDDING_ENDPOINT_URL=https://seethygerald-myfinancialapp.hf.space/embed
EMBEDDING_ENDPOINT_TOKEN=

# local mode (if using EMBEDDING_PROVIDER=local)
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2

# Other routes
GROQ_API_KEY=
